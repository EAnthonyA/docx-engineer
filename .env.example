# Copy to .env and fill in values

# Dev: plaintext password (never use in production)
ADMIN_PASSWORD=admin

# Backend URL for Vite proxy (use service name in Docker, localhost for host-based dev)
VITE_BACKEND_URL=http://backend:8000

# Prod: bcrypt hash — generate with: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpass', bcrypt.gensalt()).decode())"
# ADMIN_PASSWORD_HASH=

# Random string for signing session cookies
SESSION_SECRET=change-me-to-a-long-random-string

# Gemini API key (https://ai.google.dev/)
GEMINI_API_KEY=
# Optional: override model
GEMINI_MODEL=gemini-2.5-flash-lite
